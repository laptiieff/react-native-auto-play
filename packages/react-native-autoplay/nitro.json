{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["swe", "iternio", "reactnativeautoplay"],
  "ios": {
    "iosModuleName": "ReactNativeAutoPlay"
  },
  "android": {
    "androidNamespace": ["swe", "iternio", "reactnativeautoplay"],
    "androidCxxLibName": "ReactNativeAutoPlay"
  },
  "autolinking": {
    "AutoPlay": {
      "android": {
        "implementationClassName": "HybridAutoPlay",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridAutoPlay",
        "language": "swift"
      }
    },
    "AndroidAutoTelemetry": {
      "android": {
        "implementationClassName": "HybridAndroidAutoTelemetry",
        "language": "kotlin"
      }
    },
    "AndroidAutomotive": {
      "android": {
        "implementationClassName": "HybridAndroidAutomotive",
        "language": "kotlin"
      }
    },
    "SignInTemplate": {
      "android": {
        "implementationClassName": "HybridSignInTemplate",
        "language": "kotlin"
      }
    },
    "ListTemplate": {
      "android": {
        "implementationClassName": "HybridListTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridListTemplate",
        "language": "swift"
      }
    },
    "InformationTemplate": {
      "android": {
        "implementationClassName": "HybridInformationTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridInformationTemplate",
        "language": "swift"
      }
    },
    "GridTemplate": {
      "android": {
        "implementationClassName": "HybridGridTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridGridTemplate",
        "language": "swift"
      }
    },
    "MapTemplate": {
      "android": {
        "implementationClassName": "HybridMapTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridMapTemplate",
        "language": "swift"
      }
    },
    "MessageTemplate": {
      "android": {
        "implementationClassName": "HybridMessageTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridMessageTemplate",
        "language": "swift"
      }
    },
    "SearchTemplate": {
      "android": {
        "implementationClassName": "HybridSearchTemplate",
        "language": "kotlin"
      },
      "ios": {
        "implementationClassName": "HybridSearchTemplate",
        "language": "swift"
      }
    },
    "CarPlayDashboard": {
      "ios": {
        "implementationClassName": "HybridCarPlayDashboard",
        "language": "swift"
      }
    },
    "Cluster": {
      "android": {
        "implementationClassName": "HybridCluster",
        "language": "kotlin"
      },
      "ios": { "implementationClassName": "HybridCluster", "language": "swift" }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
